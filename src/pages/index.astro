---
import BaseLayout from '../layouts/BaseLayout.astro';
import BottomNav from '../components/BottomNav.astro';
---
<BaseLayout title="Hamzah Quran - Al Quran Custom">
  <header style="background:var(--blue)" class="sticky top-0 z-50 px-4 py-3 flex items-center gap-3">
    <div class="flex-1">
      <h1 style="font-family:'Nunito',sans-serif;color:white;font-size:1.25rem;font-weight:900">
        Hamzah Quran
      </h1>
    </div>
    <a href="/cart" class="relative">
      <span class="material-symbols-outlined" style="color:white">shopping_cart</span>
      <span data-cart-count style="background:var(--gold);color:#212121;font-size:10px;font-weight:700;position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;display:none;align-items:center;justify-content:center">0</span>
    </a>
  </header>

  <div class="px-4 py-3" style="background:var(--blue)">
    <div class="flex items-center gap-2 bg-white rounded-lg px-3 py-2">
      <span class="material-symbols-outlined" style="color:var(--text-secondary);font-size:1.1rem">search</span>
      <input
        id="search-input"
        type="text"
        placeholder="Cari produk..."
        class="flex-1 outline-none text-sm"
        style="color:var(--text-primary)"
      />
    </div>
  </div>

  <div class="p-3">
    <div id="product-grid" class="grid grid-cols-2 gap-3">
      {Array(6).fill(null).map(() => (
        <div class="bg-white rounded-lg overflow-hidden animate-pulse">
          <div class="aspect-square bg-gray-200"></div>
          <div class="p-2">
            <div class="h-3 bg-gray-200 rounded mb-2"></div>
            <div class="h-3 bg-gray-200 rounded w-2/3"></div>
          </div>
        </div>
      ))}
    </div>
    <div id="load-more" class="mt-4 text-center hidden">
      <button id="load-more-btn" class="px-6 py-2 rounded-full text-sm font-semibold" style="background:var(--blue);color:white">
        Lihat Lebih Banyak
      </button>
    </div>
  </div>

  <div class="h-20"></div>
  <BottomNav active="home" />
</BaseLayout>

<script>
  import { getProducts, addToCart, refreshCartBadge, formatRupiah } from '../lib/scalev';

  let currentPage = 1;
  let isLoading = false;
  let hasMore = true;

  function renderCard(item: any) {
    const img = item.images?.[0] || item.meta_thumbnail || '/placeholder.svg';
    const price = parseFloat(item.price_range?.min ?? item.price_range?.max ?? item.min_price ?? item.price ?? '0');
    const slug = item.slug || '';
    return `
      <div class="bg-white rounded-lg overflow-hidden shadow-sm">
        <a href="/produk/?slug=${slug}">
          <div class="aspect-square overflow-hidden bg-gray-100">
            <img src="${img}" alt="${item.name}" loading="lazy"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              onerror="this.src='/placeholder.svg'" />
          </div>
        </a>
        <div class="p-2">
          <a href="/produk/?slug=${slug}">
            <p class="text-xs font-medium line-clamp-2 mb-1" style="color:var(--text-primary)">${item.name}</p>
          </a>
          <p class="text-sm font-bold" style="color:var(--red)">${formatRupiah(price)}</p>
          <button
            class="add-to-cart mt-2 w-full py-1.5 rounded text-xs font-semibold transition-colors"
            style="background:var(--blue);color:white"
            data-variant-id="${item.variants?.[0]?.id || ''}"
          >
            + Keranjang
          </button>
        </div>
      </div>
    `;
  }

  async function loadProducts(search = '', page = 1) {
    if (isLoading) return;
    isLoading = true;

    const grid = document.getElementById('product-grid')!;
    if (page === 1) {
      grid.innerHTML = Array(6).fill(`
        <div class="bg-white rounded-lg overflow-hidden animate-pulse">
          <div class="aspect-square bg-gray-200"></div>
          <div class="p-2"><div class="h-3 bg-gray-200 rounded mb-2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div>
        </div>
      `).join('');
    }

    try {
      const data = await getProducts({ search, page, per_page: 10 });
      const items = data.results || data.items || data.data || [];

      if (page === 1) grid.innerHTML = '';

      if (!items.length && page === 1) {
        grid.innerHTML = `
          <div class="col-span-2 text-center py-16">
            <p style="color:var(--text-secondary)">Produk tidak ditemukan</p>
          </div>`;
        return;
      }

      items.forEach((item: any) => {
        grid.insertAdjacentHTML('beforeend', renderCard(item));
      });

      hasMore = items.length === 10;
      const loadMoreEl = document.getElementById('load-more')!;
      loadMoreEl.classList.toggle('hidden', !hasMore);

      grid.querySelectorAll('.add-to-cart').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          const variantId = parseInt((btn as HTMLElement).dataset.variantId || '0');
          if (!variantId) return;
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = '...';
          try {
            await addToCart(variantId, 1);
            await refreshCartBadge();
            btn.textContent = '✓ Ditambahkan';
            setTimeout(() => { btn.textContent = '+ Keranjang'; (btn as HTMLButtonElement).disabled = false; }, 1500);
          } catch {
            btn.textContent = '+ Keranjang';
            (btn as HTMLButtonElement).disabled = false;
          }
        });
      });

    } catch (err) {
      grid.innerHTML = `
        <div class="col-span-2 text-center py-16">
          <p style="color:var(--text-secondary)" class="mb-3">Gagal memuat produk</p>
          <button onclick="location.reload()" class="px-4 py-2 rounded text-sm" style="background:var(--blue);color:white">Coba Lagi</button>
        </div>`;
    } finally {
      isLoading = false;
    }
  }

  let debounce: ReturnType<typeof setTimeout>;
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    clearTimeout(debounce);
    debounce = setTimeout(() => {
      currentPage = 1;
      loadProducts((e.target as HTMLInputElement).value);
    }, 400);
  });

  document.getElementById('load-more-btn')?.addEventListener('click', () => {
    currentPage++;
    loadProducts('', currentPage);
  });

  loadProducts();
  refreshCartBadge();
</script>
