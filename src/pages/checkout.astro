---
import BaseLayout from '../layouts/BaseLayout.astro';
import BottomNav from '../components/BottomNav.astro';
---
<BaseLayout title="Checkout - Hamzah Quran">
  <header class="sticky top-0 z-50 bg-white border-b px-4 py-3" style="border-color:var(--border)">
    <a href="/cart" onclick="history.back();return false;" class="flex items-center gap-2">
      <span class="material-symbols-outlined" style="color:var(--text-primary)">arrow_back</span>
      <h1 class="font-bold text-base" style="color:var(--text-primary)">Checkout</h1>
    </a>
  </header>

  <div class="p-4 space-y-4 pb-32">
    <div class="bg-white rounded-lg p-4">
      <h3 class="text-xs font-semibold mb-3" style="color:var(--text-secondary)">DATA PENERIMA</h3>
      <div class="space-y-3">
        <input id="field-name" type="text" placeholder="Nama Lengkap" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all" style="border-color:var(--border);color:var(--text-primary)" />
        <input id="field-phone" type="tel" placeholder="Nomor HP" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all" style="border-color:var(--border);color:var(--text-primary)" />
        <input id="field-email" type="email" placeholder="Email" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all" style="border-color:var(--border);color:var(--text-primary)" />
      </div>
    </div>

    <div class="bg-white rounded-lg p-4">
      <h3 class="text-xs font-semibold mb-3" style="color:var(--text-secondary)">ALAMAT PENGIRIMAN</h3>
      <div class="space-y-3">
        <textarea id="field-address" placeholder="Alamat Lengkap (jalan, gang, no. rumah)" rows="3" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all resize-none" style="border-color:var(--border);color:var(--text-primary)"></textarea>
        <select id="field-province" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all" style="border-color:var(--border);color:var(--text-primary)">
          <option value="">Pilih Provinsi</option>
        </select>
        <select id="field-city" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all" style="border-color:var(--border);color:var(--text-primary)" disabled>
          <option value="">Pilih Kota</option>
        </select>
        <select id="field-subdistrict" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all" style="border-color:var(--border);color:var(--text-primary)" disabled>
          <option value="">Pilih Kecamatan</option>
        </select>
        <input id="field-postal" type="text" placeholder="Kode Pos" class="w-full px-3 py-2.5 bg-gray-50 rounded-lg text-sm border outline-none transition-all" style="border-color:var(--border);color:var(--text-primary)" />
      </div>
    </div>

    <div class="bg-white rounded-lg p-4">
      <h3 class="text-xs font-semibold mb-3" style="color:var(--text-secondary)">METODE PENGIRIMAN</h3>
      <button id="btn-check-ongkir" class="w-full py-2.5 rounded-lg font-semibold text-sm" style="background:var(--gold);color:#212121">
        Cek Ongkir
      </button>
      <div id="shipping-options" class="mt-3 space-y-2"></div>
    </div>

    <div class="bg-white rounded-lg p-4">
      <h3 class="text-xs font-semibold mb-3" style="color:var(--text-secondary)">METODE PEMBAYARAN</h3>
      <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
        <input type="radio" name="payment" value="transfer_bank" checked class="accent-blue-700" />
        <span class="text-sm">Transfer Bank</span>
      </div>
    </div>

    <div class="bg-white rounded-lg p-4">
      <h3 class="text-xs font-semibold mb-3" style="color:var(--text-secondary)">RINGKASAN ORDER</h3>
      <div id="checkout-items" class="space-y-2"></div>
      <div class="border-t mt-3 pt-3 space-y-1" style="border-color:var(--border)">
        <div class="flex justify-between text-sm">
          <span style="color:var(--text-secondary)">Subtotal</span>
          <span id="checkout-subtotal" class="font-medium">Rp 0</span>
        </div>
        <div class="flex justify-between text-sm">
          <span style="color:var(--text-secondary)">Ongkir</span>
          <span id="checkout-shipping" class="font-medium">Rp 0</span>
        </div>
        <div class="flex justify-between text-sm font-bold pt-2 mt-2" style="border-top:1px solid var(--border)">
          <span>Total</span>
          <span id="checkout-total" style="color:var(--red)">Rp 0</span>
        </div>
      </div>
    </div>
  </div>

  <div class="fixed bottom-16 left-1/2 -translate-x-1/2 w-full max-w-[480px] bg-white border-t p-4 z-50" style="border-color:var(--border)">
    <button id="btn-submit-order" class="w-full py-3 rounded-lg font-bold text-white text-sm disabled:opacity-50 disabled:cursor-not-allowed" style="background:var(--blue)">
      Bayar Sekarang
    </button>
  </div>

  <BottomNav active="cart" />
</BaseLayout>

<script>
  import { getGuestCart, getProvinces, getCities, getSubdistricts, getShippingOptions, submitCheckout, formatRupiah } from '../lib/scalev';

  let cartItems: any[] = [];
  let selectedShipping: any = null;
  let formData: any = {};

  const provinceEl = document.getElementById('field-province') as HTMLSelectElement;
  const cityEl = document.getElementById('field-city') as HTMLSelectElement;
  const subdistrictEl = document.getElementById('field-subdistrict') as HTMLSelectElement;

  function $(id: string) { return document.getElementById(id)!; }

  async function init() {
    try {
      const cart = await getGuestCart();
      cartItems = cart.items || [];
      if (!cartItems.length) { window.location.href = '/cart'; return; }
      renderItems();
    } catch {
      window.location.href = '/cart';
    }

    try {
      const provinces = await getProvinces();
      (provinces.data || []).forEach((p: any) => {
        const opt = document.createElement('option');
        opt.value = p.province_id; opt.textContent = p.province_name;
        provinceEl.appendChild(opt);
      });
    } catch {}
  }

  function renderItems() {
    const container = $('checkout-items');
    container.innerHTML = '';
    cartItems.forEach((item: any) => {
      const img = item.variant?.images?.[0]?.url || item.product?.images?.[0]?.url || '/placeholder.svg';
      const name = item.product?.name || 'Produk';
      container.innerHTML += `
        <div class="flex items-center gap-3">
          <img src="${img}" class="w-12 h-12 object-cover rounded bg-gray-100" />
          <div class="flex-1 min-w-0">
            <p class="text-sm line-clamp-1" style="color:var(--text-primary)">${name}</p>
            <p class="text-xs" style="color:var(--text-secondary)">${item.quantity}x</p>
          </div>
          <span class="text-sm font-medium">${formatRupiah(item.price * item.quantity)}</span>
        </div>
      `;
    });
    const subtotal = cartItems.reduce((s: number, i: any) => s + i.price * i.quantity, 0);
    $('checkout-subtotal').textContent = formatRupiah(subtotal);
    updateTotal();
  }

  function updateTotal() {
    const subtotal = cartItems.reduce((s: number, i: any) => s + i.price * i.quantity, 0);
    const shipping = selectedShipping?.cost || 0;
    $('checkout-shipping').textContent = formatRupiah(shipping);
    $('checkout-total').textContent = formatRupiah(subtotal + shipping);
  }

  provinceEl.addEventListener('change', async () => {
    cityEl.innerHTML = '<option value="">Pilih Kota</option>';
    cityEl.disabled = true;
    subdistrictEl.innerHTML = '<option value="">Pilih Kecamatan</option>';
    subdistrictEl.disabled = true;
    if (!provinceEl.value) return;
    try {
      const cities = await getCities(parseInt(provinceEl.value));
      cityEl.disabled = false;
      (cities.data || []).forEach((c: any) => {
        const opt = document.createElement('option');
        opt.value = c.city_id; opt.textContent = c.city_name;
        cityEl.appendChild(opt);
      });
    } catch {}
  });

  cityEl.addEventListener('change', async () => {
    subdistrictEl.innerHTML = '<option value="">Pilih Kecamatan</option>';
    subdistrictEl.disabled = true;
    if (!cityEl.value) return;
    try {
      const subdistricts = await getSubdistricts(parseInt(cityEl.value));
      subdistrictEl.disabled = false;
      (subdistricts.data || []).forEach((s: any) => {
        const opt = document.createElement('option');
        opt.value = s.id; opt.textContent = s.subdistrict_name;
        subdistrictEl.appendChild(opt);
      });
    } catch {}
  });

  $('btn-check-ongkir').addEventListener('click', async () => {
    formData = {
      name: ($('field-name') as HTMLInputElement).value,
      phone: ($('field-phone') as HTMLInputElement).value,
      email: ($('field-email') as HTMLInputElement).value,
      address: ($('field-address') as HTMLTextAreaElement).value,
      province_id: provinceEl.value,
      city_id: cityEl.value,
      subdistrict_id: subdistrictEl.value,
      postal_code: ($('field-postal') as HTMLInputElement).value,
    };

    if (!formData.name || !formData.phone || !formData.address || !formData.province_id || !formData.city_id || !formData.subdistrict_id) {
      alert('Lengkapi alamat pengiriman terlebih dahulu');
      return;
    }

    const btn = $('btn-check-ongkir') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Memuat...';

    try {
      const options = await getShippingOptions(formData);
      const container = $('shipping-options');
      container.innerHTML = '';
      options.forEach((opt: any, idx: number) => {
        const div = document.createElement('div');
        div.className = 'flex items-center gap-3 p-3 bg-gray-50 rounded-lg cursor-pointer hover:bg-gray-100 transition-colors';
        div.innerHTML = `
          <input type="radio" name="shipping" value="${idx}" class="accent-blue-700" />
          <div class="flex-1">
            <p class="text-sm font-medium">${opt.courier} - ${opt.service}</p>
            <p class="text-xs" style="color:var(--text-secondary)">Estimasi: ${opt.estimation}</p>
          </div>
          <span class="text-sm font-bold" style="color:var(--red)">${formatRupiah(opt.cost)}</span>
        `;
        div.addEventListener('click', () => {
          container.querySelectorAll('div').forEach(d => d.classList.remove('ring-2', 'ring-blue-700'));
          div.classList.add('ring-2', 'ring-blue-700');
          selectedShipping = opt;
          div.querySelector('input')!.checked = true;
          updateTotal();
        });
        container.appendChild(div);
      });
    } catch {
      alert('Gagal mengecek ongkir');
    } finally {
      btn.disabled = false; btn.textContent = 'Cek Ongkir';
    }
  });

  $('btn-submit-order').addEventListener('click', async () => {
    if (!selectedShipping) { alert('Pilih metode pengiriman'); return; }

    const btn = $('btn-submit-order') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Memproses...';

    try {
      const order = await submitCheckout({
        customer_name: formData.name,
        customer_phone: formData.phone,
        customer_email: formData.email,
        address: formData.address,
        province_id: parseInt(formData.province_id),
        city_id: parseInt(formData.city_id),
        subdistrict_id: parseInt(formData.subdistrict_id),
        postal_code: formData.postal_code,
        shipping_option: `${selectedShipping.courier} - ${selectedShipping.service}`,
        shipping_cost: selectedShipping.cost,
        payment_method: 'transfer_bank',
      });
      localStorage.removeItem('scalev_guest_token');
      window.location.href = `/order/?slug=${order.secret_slug}`;
    } catch (err: any) {
      alert(err.message || 'Gagal memproses pesanan');
      btn.disabled = false; btn.textContent = 'Bayar Sekarang';
    }
  });

  init();
</script>
