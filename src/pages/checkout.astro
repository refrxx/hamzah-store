---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Checkout - Hamzah Quran">
  <header class="sticky top-0 z-50 bg-white border-b px-4 py-3 flex items-center gap-2" style="border-color:#e0e0e0">
    <a href="/cart" onclick="history.back();return false;" class="flex items-center gap-2">
      <span class="material-symbols-outlined" style="color:var(--text-primary)">arrow_back</span>
    </a>
    <h1 class="font-bold text-base" style="color:var(--text-primary)">Checkout</h1>
  </header>

  <div class="py-3 space-y-3">
    <!-- Alamat Pengiriman -->
    <div class="bg-white rounded-lg mx-3 mb-3 overflow-hidden">
      <div class="px-4 py-3 border-b flex items-center gap-2" style="border-color:#f0f0f0">
        <span class="material-symbols-outlined text-sm" style="color:var(--blue)">location_on</span>
        <span class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-secondary)">Alamat Pengiriman</span>
      </div>
      <div class="p-4 space-y-3">
        <div class="flex gap-3">
          <input id="field-name" type="text" placeholder="Nama lengkap"
            class="w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-colors"
            style="border-color:#e0e0e0;color:var(--text-primary)"
            onfocus="this.style.borderColor='#1A5FB4'" onblur="this.style.borderColor='#e0e0e0'" />
          <input id="field-phone" type="tel" placeholder="No. HP"
            class="w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-colors"
            style="border-color:#e0e0e0;color:var(--text-primary)"
            onfocus="this.style.borderColor='#1A5FB4'" onblur="this.style.borderColor='#e0e0e0'" />
        </div>
        <textarea id="field-address" placeholder="Alamat lengkap (jalan, gang, no. rumah)" rows="2"
          class="w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-colors resize-none"
          style="border-color:#e0e0e0;color:var(--text-primary)"
          onfocus="this.style.borderColor='#1A5FB4'" onblur="this.style.borderColor='#e0e0e0'"></textarea>
        <div class="flex gap-3">
          <select id="field-province"
            class="flex-1 px-3 py-2.5 rounded-lg border text-sm outline-none appearance-none bg-white"
            style="border-color:#e0e0e0;color:var(--text-primary)">
            <option value="">Provinsi</option>
          </select>
          <select id="field-city"
            class="flex-1 px-3 py-2.5 rounded-lg border text-sm outline-none appearance-none bg-white"
            style="border-color:#e0e0e0;color:var(--text-primary)" disabled>
            <option value="">Kota</option>
          </select>
        </div>
        <div class="flex gap-3">
          <select id="field-subdistrict"
            class="flex-1 px-3 py-2.5 rounded-lg border text-sm outline-none appearance-none bg-white"
            style="border-color:#e0e0e0;color:var(--text-primary)" disabled>
            <option value="">Kecamatan</option>
          </select>
          <input id="field-postal" type="text" placeholder="Kode Pos"
            class="w-28 px-3 py-2.5 rounded-lg border text-sm outline-none transition-colors"
            style="border-color:#e0e0e0;color:var(--text-primary)"
            onfocus="this.style.borderColor='#1A5FB4'" onblur="this.style.borderColor='#e0e0e0'" />
        </div>
        <input id="field-email" type="email" placeholder="Email (opsional)"
          class="w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-colors"
          style="border-color:#e0e0e0;color:var(--text-primary)"
          onfocus="this.style.borderColor='#1A5FB4'" onblur="this.style.borderColor='#e0e0e0'" />
      </div>
    </div>

    <!-- Produk -->
    <div class="bg-white rounded-lg mx-3 mb-3 overflow-hidden">
      <div class="px-4 py-3 border-b flex items-center gap-2" style="border-color:#f0f0f0">
        <span class="material-symbols-outlined text-sm" style="color:var(--blue)">inventory_2</span>
        <span class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-secondary)">Produk</span>
      </div>
      <div id="cart-items-preview" class="p-4">
        <div class="flex items-center justify-center py-8">
          <div class="w-5 h-5 border-2 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
        </div>
      </div>
    </div>

    <!-- Opsi Pengiriman -->
    <div class="bg-white rounded-lg mx-3 mb-3 overflow-hidden">
      <div class="px-4 py-3 border-b flex items-center gap-2" style="border-color:#f0f0f0">
        <span class="material-symbols-outlined text-sm" style="color:var(--blue)">local_shipping</span>
        <span class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-secondary)">Opsi Pengiriman</span>
      </div>
      <div class="p-4">
        <button id="btn-check-ongkir"
          class="w-full py-2.5 rounded-lg font-semibold text-sm text-white transition-opacity"
          style="background:var(--blue)">
          Cek Ongkir
        </button>
        <div id="shipping-options" class="mt-3 space-y-2"></div>
      </div>
    </div>

    <!-- Metode Pembayaran -->
    <div class="bg-white rounded-lg mx-3 mb-3 overflow-hidden">
      <div class="px-4 py-3 border-b flex items-center gap-2" style="border-color:#f0f0f0">
        <span class="material-symbols-outlined text-sm" style="color:var(--blue)">account_balance</span>
        <span class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-secondary)">Metode Pembayaran</span>
      </div>
      <div class="p-4">
        <div class="flex items-center gap-3 p-3 rounded-lg border" style="border-color:#e0e0e0">
          <input type="radio" name="payment" value="bank_transfer" checked class="accent-blue-700" />
          <span class="text-sm font-medium" style="color:var(--text-primary)">Transfer Bank</span>
        </div>
      </div>
    </div>

    <!-- Rincian Pembayaran -->
    <div class="bg-white rounded-lg mx-3 mb-3 overflow-hidden">
      <div class="px-4 py-3 border-b flex items-center gap-2" style="border-color:#f0f0f0">
        <span class="material-symbols-outlined text-sm" style="color:var(--blue)">receipt_long</span>
        <span class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-secondary)">Rincian Pembayaran</span>
      </div>
      <div class="p-4 space-y-2">
        <div class="flex justify-between text-sm">
          <span style="color:var(--text-secondary)">Subtotal Produk</span>
          <span id="summary-subtotal" class="font-medium" style="color:var(--text-primary)">Rp 0</span>
        </div>
        <div class="flex justify-between text-sm">
          <span style="color:var(--text-secondary)">Ongkos Kirim</span>
          <span id="summary-shipping" class="font-medium" style="color:var(--text-primary)">-</span>
        </div>
        <div class="border-t pt-2 mt-2 flex justify-between text-sm font-bold" style="border-color:#f0f0f0">
          <span>Total</span>
          <span id="summary-total" style="color:var(--blue)">Rp 0</span>
        </div>
      </div>
    </div>
  </div>

  <div class="h-24"></div>

  <!-- Sticky Bottom Bar -->
  <div class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-[480px] bg-white border-t z-50 p-3 flex items-center gap-3" style="border-color:#e0e0e0">
    <div class="flex-1">
      <p class="text-xs" style="color:var(--text-secondary)">Total Pembayaran</p>
      <p id="sticky-total" class="text-base font-bold" style="color:var(--blue)">Rp 0</p>
    </div>
    <button id="submit-checkout-btn"
      class="px-6 py-3 rounded-lg text-white font-bold text-sm flex-shrink-0 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
      style="background:var(--blue)">
      Buat Pesanan
    </button>
  </div>
</BaseLayout>

<script>
  import { getGuestCart, getProvinces, getCities, getSubdistricts, getShippingOptions, submitCheckout, formatRupiah } from '../lib/scalev';

  let cartItems: any[] = [];
  let selectedShipping: any = null;
  let selectedLocationId: number | null = null;

  const provinceEl = document.getElementById('field-province') as HTMLSelectElement;
  const cityEl = document.getElementById('field-city') as HTMLSelectElement;
  const subdistrictEl = document.getElementById('field-subdistrict') as HTMLSelectElement;

  function $(id: string) { return document.getElementById(id)!; }

  function formatRupiahInline(amount: number) {
    return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(amount);
  }

  async function init() {
    try {
      const cart = await getGuestCart();
      cartItems = cart.items || [];
      if (!cartItems.length) { window.location.href = '/cart'; return; }
      renderCartItems();
      updatePaymentSummary(0);
    } catch {
      window.location.href = '/cart';
    }

    try {
      const provinces = await getProvinces();
      (provinces.data || []).forEach((p: any) => {
        const opt = document.createElement('option');
        opt.value = p.province_id; opt.textContent = p.province_name;
        provinceEl.appendChild(opt);
      });
    } catch {}
  }

  function renderCartItems() {
    const container = $('cart-items-preview');
    container.innerHTML = cartItems.map((item: any) => {
      const img = item.variant?.images?.[0]?.url || item.product?.images?.[0]?.url || '/placeholder.svg';
      const name = item.product?.name || 'Produk';
      const variant = item.variant?.name || '';
      const price = item.price || 0;
      return `
        <div class="flex gap-3 py-3 border-b last:border-0" style="border-color:#f0f0f0">
          <img src="${img}" class="w-14 h-14 rounded-lg object-cover flex-shrink-0 bg-gray-100" onerror="this.src='/placeholder.svg'" />
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium line-clamp-2" style="color:var(--text-primary)">${name}</p>
            ${variant ? `<p class="text-xs mt-0.5" style="color:var(--text-secondary)">${variant}</p>` : ''}
            <div class="flex items-center justify-between mt-1">
              <span class="text-sm font-bold" style="color:var(--blue)">${formatRupiah(price)}</span>
              <span class="text-xs" style="color:var(--text-secondary)">x${item.quantity}</span>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  function updatePaymentSummary(shippingCost = 0) {
    const subtotal = cartItems.reduce((sum: number, item: any) => sum + (item.price * item.quantity), 0);
    const total = subtotal + shippingCost;

    $('summary-subtotal').textContent = formatRupiahInline(subtotal);
    $('summary-shipping').textContent = shippingCost > 0 ? formatRupiahInline(shippingCost) : '-';
    $('summary-total').textContent = formatRupiahInline(total);
    $('sticky-total').textContent = formatRupiahInline(total);
  }

  provinceEl.addEventListener('change', async () => {
    cityEl.innerHTML = '<option value="">Kota</option>';
    cityEl.disabled = true;
    subdistrictEl.innerHTML = '<option value="">Kecamatan</option>';
    subdistrictEl.disabled = true;
    selectedLocationId = null;
    if (!provinceEl.value) return;
    try {
      const cities = await getCities(parseInt(provinceEl.value));
      cityEl.disabled = false;
      (cities.data || []).forEach((c: any) => {
        const opt = document.createElement('option');
        opt.value = c.city_id; opt.textContent = c.city_name;
        cityEl.appendChild(opt);
      });
    } catch {}
  });

  cityEl.addEventListener('change', async () => {
    subdistrictEl.innerHTML = '<option value="">Kecamatan</option>';
    subdistrictEl.disabled = true;
    selectedLocationId = null;
    if (!cityEl.value) return;
    try {
      const subdistricts = await getSubdistricts(parseInt(cityEl.value));
      subdistrictEl.disabled = false;
      (subdistricts.data || []).forEach((s: any) => {
        const opt = document.createElement('option');
        opt.value = s.id; opt.textContent = s.subdistrict_name;
        subdistrictEl.appendChild(opt);
      });
    } catch {}
  });

  subdistrictEl.addEventListener('change', () => {
    selectedLocationId = subdistrictEl.value ? parseInt(subdistrictEl.value) : null;
  });

  function buildCartItemsPayload() {
    return cartItems.map((item: any) => {
      if (item.type === 'variant') {
        return { type: 'variant', variant_id: item.variant_id, quantity: item.quantity };
      } else if (item.type === 'bundle_price_option') {
        return { type: 'bundle_price_option', bundle_price_option_id: item.bundle_price_option_id, quantity: item.quantity };
      }
    }).filter(Boolean);
  }

  $('btn-check-ongkir').addEventListener('click', async () => {
    const name = ($('field-name') as HTMLInputElement).value.trim();
    const phone = ($('field-phone') as HTMLInputElement).value.trim();
    const address = ($('field-address') as HTMLTextAreaElement).value.trim();
    const postalCode = ($('field-postal') as HTMLInputElement).value.trim();

    if (!name || !phone || !address || !provinceEl.value || !cityEl.value || !subdistrictEl.value) {
      alert('Lengkapi alamat pengiriman terlebih dahulu');
      return;
    }

    const btn = $('btn-check-ongkir') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Memuat...';

    try {
      const cartItemsPayload = buildCartItemsPayload();
      if (!cartItemsPayload.length) { alert('Keranjang kosong!'); return; }

      const payload = {
        items: cartItemsPayload,
        location_id: parseInt(subdistrictEl.value),
        shipping_province: provinceEl.options[provinceEl.selectedIndex].text,
        shipping_city: cityEl.options[cityEl.selectedIndex].text,
        shipping_subdistrict: subdistrictEl.options[subdistrictEl.selectedIndex].text,
        shipping_postal_code: postalCode,
      };

      console.log('Shipping options payload:', JSON.stringify(payload, null, 2));

      const result = await getShippingOptions(payload);
      console.log('Shipping options response:', result);

      const options = result.data || [];
      const container = $('shipping-options');
      container.innerHTML = '';

      if (!options.length) {
        container.innerHTML = '<p class="text-sm text-gray-500 text-center py-4">Tidak ada opsi pengiriman tersedia</p>';
        return;
      }

      const courierNames: Record<string, string> = {
        jnt: 'J&T', jne: 'JNE', anteraja: 'AnterAja', self_courier: 'Kurir Toko',
        sicepat: 'SiCepat', ide: 'ID Express', ninja: 'Ninja Xpress',
      };

      options.forEach((opt: any) => {
        const courierLabel = courierNames[opt.courier_code] || opt.courier_code?.toUpperCase() || 'Kurir';
        const serviceLabel = opt.name || opt.service_code || '';
        const displayName = `${courierLabel} ${serviceLabel}`.trim();
        const etd = opt.etd ? `${opt.etd} hari` : '-';
        const price = opt.cost || 0;
        const isCod = opt.is_cod;

        const div = document.createElement('div');
        div.className = 'flex items-center gap-3 p-3 rounded-lg border cursor-pointer transition-colors';
        div.style.borderColor = '#e0e0e0';
        div.innerHTML = `
          <input type="radio" name="shipping" value="${opt.courier_service_id}" data-cost="${price}" data-warehouse="${opt.warehouse_unique_id}" class="accent-blue-700 flex-shrink-0" />
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium" style="color:var(--text-primary)">${displayName}</p>
            <p class="text-xs" style="color:var(--text-secondary)">Estimasi: ${etd}${isCod ? ' · <span style="color:green">COD</span>' : ''}</p>
          </div>
          <span class="text-sm font-bold flex-shrink-0" style="color:var(--blue)">${price === 0 ? 'Gratis' : formatRupiah(price)}</span>
        `;
        div.addEventListener('click', () => {
          container.querySelectorAll('.ring-2').forEach(el => el.classList.remove('ring-2', 'ring-[#1A5FB4]'));
          div.classList.add('ring-2', 'ring-[#1A5FB4]');
          div.querySelector('input')!.checked = true;
          selectedShipping = opt;
          updatePaymentSummary(price);
        });
        container.appendChild(div);
      });
    } catch (err) {
      console.error('Shipping options error:', err);
      alert('Gagal mengecek ongkir');
    } finally {
      btn.disabled = false; btn.textContent = 'Cek Ongkir';
    }
  });

  function buildCheckoutPayload() {
    const selectedRadio = document.querySelector('input[name="shipping"]:checked') as HTMLInputElement;
    if (!selectedRadio) throw new Error('Pilih metode pengiriman');

    let phone = (($('field-phone') as HTMLInputElement).value || '').replace(/\D/g, '');
    if (phone.startsWith('0')) phone = '62' + phone.slice(1);
    if (phone.startsWith('+')) phone = phone.slice(1);

    return {
      items: buildCartItemsPayload(),
      customer_name: ($('field-name') as HTMLInputElement).value.trim(),
      customer_email: ($('field-email') as HTMLInputElement).value.trim(),
      customer_phone: phone,
      shipping_address: ($('field-address') as HTMLTextAreaElement).value.trim(),
      shipping_province: provinceEl.options[provinceEl.selectedIndex]?.text || '',
      shipping_city: cityEl.options[cityEl.selectedIndex]?.text || '',
      shipping_subdistrict: subdistrictEl.options[subdistrictEl.selectedIndex]?.text || '',
      shipping_postal_code: ($('field-postal') as HTMLInputElement).value.trim(),
      location_id: selectedLocationId || parseInt(subdistrictEl.value),
      courier_service_id: parseInt(selectedRadio.value),
      warehouse_unique_id: selectedRadio.dataset.warehouse || '',
      shipping_cost: parseInt(selectedRadio.dataset.cost || '0'),
      payment_method: 'bank_transfer',
    };
  }

  $('submit-checkout-btn').addEventListener('click', async () => {
    try {
      const payload = buildCheckoutPayload();
      console.log('Checkout payload:', JSON.stringify(payload, null, 2));

      const btn = $('submit-checkout-btn') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Memproses...';

      const order = await submitCheckout(payload);
      localStorage.removeItem('scalev_guest_token');
      window.location.href = `/order/?slug=${order.secret_slug}`;
    } catch (err: any) {
      console.error('Checkout error:', err);
      alert(err.message || 'Gagal memproses pesanan');
      const btn = $('submit-checkout-btn') as HTMLButtonElement;
      btn.disabled = false; btn.textContent = 'Buat Pesanan';
    }
  });

  document.addEventListener('change', (e: Event) => {
    const target = e.target as HTMLInputElement;
    if (target.name === 'shipping') {
      const cost = parseFloat(target.dataset.cost || '0');
      updatePaymentSummary(cost);
    }
  });

  init();
</script>