---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/PageShell.astro';
import BottomNav from '../../components/BottomNav.astro';
import Toast from '../../components/Toast.astro';

export const prerender = false;

const title = 'Pesanan | Hamzah Quran';
---

<BaseLayout {title}>
  <PageShell showBottomNav={false}>
    <Fragment slot="header">
      <header class="sticky top-0 z-40 bg-white border-b border-gray-200">
        <div class="flex items-center h-14 px-4">
          <a href="/" class="p-2 -ml-2" aria-label="Ke Beranda">
            <svg class="w-6 h-6 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </a>
          <span class="ml-2 text-sm font-medium text-text-primary">Konfirmasi Pesanan</span>
        </div>
      </header>
    </Fragment>

    <div id="order-skeleton" class="p-4 space-y-4">
      <div class="text-center animate-pulse">
        <div class="w-16 h-16 bg-gray-200 rounded-full mx-auto"></div>
        <div class="h-5 bg-gray-200 rounded w-48 mx-auto mt-3"></div>
        <div class="h-4 bg-gray-200 rounded w-32 mx-auto mt-2"></div>
      </div>
      <div class="bg-card rounded-lg p-4 border border-gray-100">
        <div class="h-4 bg-gray-200 rounded w-1/2"></div>
        <div class="h-4 bg-gray-200 rounded w-1/3 mt-3"></div>
      </div>
      <div class="bg-card rounded-lg p-4 border border-gray-100">
        <div class="h-4 bg-gray-200 rounded w-1/2"></div>
        <div class="h-4 bg-gray-200 rounded w-full mt-3"></div>
      </div>
    </div>

    <div id="order-content" class="hidden p-4 space-y-4 pb-32">
      <div class="text-center">
        <svg class="w-16 h-16 mx-auto text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h2 class="text-lg font-bold text-text-primary mt-3">Pesanan Berhasil Dibuat!</h2>
        <p id="order-id" class="text-sm text-text-secondary mt-1"></p>
        <p id="order-date" class="text-xs text-text-secondary"></p>
      </div>

      <div class="bg-card rounded-lg p-4 border border-gray-100">
        <h3 class="text-sm font-semibold text-text-primary mb-3">Detail Produk</h3>
        <div id="order-items" class="space-y-2"></div>
      </div>

      <div class="bg-card rounded-lg p-4 border border-gray-100">
        <h3 class="text-sm font-semibold text-text-primary mb-3">Instruksi Pembayaran</h3>
        <div id="payment-info" class="space-y-1 text-sm">
          <p><span class="text-text-secondary">Bank:</span> <span id="pay-bank" class="font-medium"></span></p>
          <p><span class="text-text-secondary">No. Rekening:</span> <span id="pay-account" class="font-medium"></span></p>
          <p><span class="text-text-secondary">Atas Nama:</span> <span id="pay-name" class="font-medium"></span></p>
          <p class="mt-2"><span class="text-text-secondary">Total Bayar:</span> <span id="pay-total" class="font-bold text-brand text-lg"></span></p>
          <p><span class="text-text-secondary">Batas Bayar:</span> <span id="pay-due" class="font-medium text-red-500"></span></p>
        </div>
      </div>

      <div class="bg-card rounded-lg p-4 border border-gray-100">
        <h3 class="text-sm font-semibold text-text-primary mb-3">Upload Bukti Transfer</h3>
        <input type="file" id="proof-file" accept="image/*" class="w-full text-sm file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand file:text-white hover:file:bg-brand-dark cursor-pointer" />
        <button id="btn-upload-proof" class="w-full mt-3 py-2.5 bg-brand text-white font-semibold rounded-lg text-sm hover:bg-brand-dark transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Upload Bukti
        </button>
        <p id="upload-status" class="text-xs text-text-secondary mt-2 text-center"></p>
      </div>

      <a
        id="wa-link"
        href="#"
        target="_blank"
        class="flex items-center justify-center gap-2 w-full py-3 bg-green-500 text-white font-semibold rounded-lg text-sm hover:bg-green-600 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Hubungi CS via WhatsApp
      </a>
    </div>

    <div id="order-error" class="hidden text-center py-20 px-4">
      <p class="text-text-secondary mb-3">Pesanan tidak ditemukan</p>
      <a href="/" class="inline-block px-6 py-2.5 bg-brand text-white rounded-lg text-sm font-medium">Kembali ke Beranda</a>
    </div>

    <Fragment slot="bottom-nav">
      <BottomNav active="orders" />
    </Fragment>
  </PageShell>
  <Toast />
</BaseLayout>

<script>
  import { getOrderBySlug, uploadTransferProof, updateOrderTransferProof, type ScalevOrder } from '../../lib/scalev';
  import { refreshCartBadge } from '../../lib/store';

  const secretSlug = window.location.pathname.split('/').pop()!;
  let order: ScalevOrder | null = null;

  const skeleton = document.getElementById('order-skeleton')!;
  const content = document.getElementById('order-content')!;
  const errorEl = document.getElementById('order-error')!;

  async function init() {
    try {
      order = await getOrderBySlug(secretSlug);
      render();
      skeleton.classList.add('hidden');
      content.classList.remove('hidden');
    } catch {
      skeleton.classList.add('hidden');
      errorEl.classList.remove('hidden');
    }
  }

  function formatPrice(v: number) {
    return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(v);
  }

  function formatDate(dateStr: string) {
    const d = new Date(dateStr);
    return d.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function render() {
    if (!order) return;

    document.getElementById('order-id')!.textContent = `Order #${order.id}`;
    document.getElementById('order-date')!.textContent = formatDate(order.created_at);

    const itemsEl = document.getElementById('order-items')!;
    order.items.forEach((item) => {
      const div = document.createElement('div');
      div.className = 'flex items-center gap-3';
      div.innerHTML = `
        <img src="${item.image_url || '/img/placeholder.svg'}" alt="${item.name}" class="w-12 h-12 object-cover rounded bg-gray-100" loading="lazy" />
        <div class="flex-1 min-w-0">
          <p class="text-sm text-text-primary line-clamp-1">${item.name}</p>
          <p class="text-xs text-text-secondary">${item.quantity}x ${formatPrice(item.price)}</p>
        </div>
        <span class="text-sm font-medium">${formatPrice(item.subtotal)}</span>
      `;
      itemsEl.appendChild(div);
    });

    if (order.payment_instructions) {
      document.getElementById('pay-bank')!.textContent = order.payment_instructions.bank_name;
      document.getElementById('pay-account')!.textContent = order.payment_instructions.account_number;
      document.getElementById('pay-name')!.textContent = order.payment_instructions.account_name;
    }
    document.getElementById('pay-total')!.textContent = formatPrice(order.gross_revenue);
    document.getElementById('pay-due')!.textContent = formatDate(order.payment_due_at);

    const waLink = document.getElementById('wa-link') as HTMLAnchorElement;
    waLink.href = `https://wa.me/?text=Halo%20saya%20ingin%20konfirmasi%20pesanan%20${order.id}`;

    document.title = `Pesanan #${order.id} | Hamzah Quran`;
  }

  const fileInput = document.getElementById('proof-file') as HTMLInputElement;
  const btnUpload = document.getElementById('btn-upload-proof')!;
  const uploadStatus = document.getElementById('upload-status')!;

  btnUpload.addEventListener('click', async () => {
    const file = fileInput.files?.[0];
    if (!file) {
      (window as any).showToast?.({ message: 'Pilih file bukti transfer terlebih dahulu', type: 'error' });
      return;
    }

    btnUpload.disabled = true;
    btnUpload.textContent = 'Mengupload...';
    uploadStatus.textContent = '';

    try {
      const result = await uploadTransferProof(secretSlug, file);
      await updateOrderTransferProof(secretSlug, result.transfer_proof_url);
      uploadStatus.textContent = 'Bukti transfer berhasil diupload!';
      uploadStatus.className = 'text-xs text-green-600 mt-2 text-center';
      btnUpload.textContent = 'Upload Berhasil';
      (window as any).showToast?.({ message: 'Bukti transfer berhasil diupload', type: 'success' });
    } catch {
      uploadStatus.textContent = 'Gagal upload. Silakan coba lagi.';
      uploadStatus.className = 'text-xs text-red-500 mt-2 text-center';
      btnUpload.disabled = false;
      btnUpload.textContent = 'Upload Bukti';
      (window as any).showToast?.({ message: 'Gagal upload bukti transfer', type: 'error' });
    }
  });

  refreshCartBadge();
  init();
</script>
