---
import BaseLayout from '../layouts/BaseLayout.astro';
import BottomNav from '../components/BottomNav.astro';
---
<BaseLayout title="Keranjang - Hamzah Quran">
  <header class="sticky top-0 z-50 bg-white border-b px-4 py-3" style="border-color:var(--border)">
    <h1 class="font-bold text-base" style="color:var(--text-primary)">Keranjang Belanja</h1>
  </header>

  <div id="cart-loading" class="p-4 space-y-3">
    {Array(3).fill(null).map(() => (
      <div class="bg-white rounded-lg p-3 flex gap-3 animate-pulse">
        <div class="w-16 h-16 bg-gray-200 rounded-lg flex-shrink-0"></div>
        <div class="flex-1"><div class="h-3 bg-gray-200 rounded mb-2"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div></div>
      </div>
    ))}
  </div>

  <div id="cart-empty" class="hidden flex flex-col items-center justify-center py-24 px-8 text-center">
    <span class="material-symbols-outlined text-gray-300 mb-4" style="font-size:5rem">shopping_cart</span>
    <p class="font-bold text-base mb-2" style="color:var(--text-primary)">Keranjang Kosong</p>
    <p class="text-sm mb-6" style="color:var(--text-secondary)">Yuk belanja dulu!</p>
    <a href="/" class="px-6 py-2 rounded-lg text-white text-sm font-bold" style="background:var(--blue)">Lihat Produk</a>
  </div>

  <div id="cart-content" class="hidden pb-40">
    <div id="cart-items" class="p-4 space-y-3"></div>
  </div>

  <div id="cart-summary" class="fixed bottom-16 left-1/2 -translate-x-1/2 w-full max-w-[480px] bg-white border-t p-4 z-40 hidden" style="border-color:var(--border)">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm" style="color:var(--text-secondary)">Total</span>
      <span id="cart-total" class="text-lg font-bold" style="color:var(--red)">Rp 0</span>
    </div>
    <a href="/checkout" id="checkout-btn" class="block w-full py-3 rounded-lg text-center font-bold text-white text-sm" style="background:var(--blue)">
      Checkout (<span id="cart-count-text">0</span> produk)
    </a>
  </div>

  <BottomNav active="cart" />
</BaseLayout>

<script>
  import { getGuestCart, updateCartItem, removeCartItem, formatRupiah } from '../lib/scalev';

  async function loadCart() {
    const loadingEl = document.getElementById('cart-loading')!;
    const emptyEl = document.getElementById('cart-empty')!;
    const contentEl = document.getElementById('cart-content')!;
    const summaryEl = document.getElementById('cart-summary')!;

    try {
      const cart = await getGuestCart();
      const items: any[] = cart.items || [];

      loadingEl.classList.add('hidden');

      if (!items.length) {
        emptyEl.classList.remove('hidden');
        return;
      }

      contentEl.classList.remove('hidden');
      summaryEl.classList.remove('hidden');

      renderItems(items);
      updateSummary(items);

    } catch {
      loadingEl.innerHTML = `
        <div class="text-center py-16">
          <p style="color:var(--text-secondary)" class="mb-3">Gagal memuat keranjang</p>
          <button onclick="location.reload()" class="px-4 py-2 rounded text-sm text-white" style="background:var(--blue)">Coba Lagi</button>
        </div>`;
    }
  }

  function renderItems(items: any[]) {
    const container = document.getElementById('cart-items')!;
    container.innerHTML = items.map((item: any) => {
      const img = item.variant?.images?.[0]?.url || item.product?.images?.[0]?.url || '/placeholder.svg';
      const name = item.product?.name || 'Produk';
      const variant = item.variant?.name || '';
      const price = item.price || item.variant?.price || 0;
      return `
        <div class="bg-white rounded-lg p-3 flex gap-3" data-item-id="${item.id}">
          <img src="${img}" alt="${name}" class="w-16 h-16 object-cover rounded-lg flex-shrink-0" onerror="this.src='/placeholder.svg'" />
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium line-clamp-2 mb-0.5" style="color:var(--text-primary)">${name}</p>
            ${variant ? `<p class="text-xs mb-1" style="color:var(--text-secondary)">${variant}</p>` : ''}
            <p class="text-sm font-bold" style="color:var(--red)">${formatRupiah(price)}</p>
            <div class="flex items-center justify-between mt-2">
              <div class="flex items-center gap-2">
                <button class="qty-minus w-6 h-6 rounded border text-xs font-bold flex items-center justify-center" style="border-color:var(--blue);color:var(--blue)" data-id="${item.id}" data-qty="${item.quantity}">−</button>
                <span class="qty-val text-xs font-bold w-4 text-center">${item.quantity}</span>
                <button class="qty-plus w-6 h-6 rounded text-xs font-bold text-white flex items-center justify-center" style="background:var(--blue)" data-id="${item.id}" data-qty="${item.quantity}">+</button>
              </div>
              <button class="remove-btn text-xs" style="color:var(--text-secondary)" data-id="${item.id}">Hapus</button>
            </div>
          </div>
        </div>
      `;
    }).join('');

    container.querySelectorAll('.qty-minus').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = parseInt((btn as HTMLElement).dataset.id || '0');
        const qty = parseInt((btn as HTMLElement).dataset.qty || '1');
        if (qty <= 1) return;
        await updateCartItem(id, qty - 1);
        loadCart();
      });
    });

    container.querySelectorAll('.qty-plus').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = parseInt((btn as HTMLElement).dataset.id || '0');
        const qty = parseInt((btn as HTMLElement).dataset.qty || '1');
        await updateCartItem(id, qty + 1);
        loadCart();
      });
    });

    container.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = parseInt((btn as HTMLElement).dataset.id || '0');
        await removeCartItem(id);
        loadCart();
      });
    });
  }

  function updateSummary(items: any[]) {
    const total = items.reduce((sum: number, item: any) => sum + (item.price || 0) * item.quantity, 0);
    const count = items.reduce((sum: number, item: any) => sum + item.quantity, 0);
    document.getElementById('cart-total')!.textContent = formatRupiah(total);
    document.getElementById('cart-count-text')!.textContent = String(count);
  }

  loadCart();
</script>
