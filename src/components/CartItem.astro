---
export interface Props {
  itemId: string;
  name: string;
  image: string;
  price: number;
  quantity: number;
  variantName?: string;
}

const { itemId, name, image, price, quantity, variantName } = Astro.props;
---

<div class="flex gap-3 bg-card p-3 rounded-lg border border-gray-100" data-cart-item={itemId}>
  <img
    src={image || '/img/placeholder.svg'}
    alt={name}
    class="w-20 h-20 object-cover rounded-lg flex-shrink-0 bg-gray-100"
    loading="lazy"
  />
  <div class="flex-1 min-w-0">
    <h3 class="text-sm font-medium text-text-primary line-clamp-2">{name}</h3>
    {variantName && (
      <p class="text-xs text-text-secondary mt-0.5">{variantName}</p>
    )}
    <div class="flex items-center justify-between mt-2">
      <span class="text-sm font-bold text-brand">{new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(price)}</span>
      <div class="flex items-center gap-2">
        <button
          class="w-7 h-7 rounded-full border border-gray-300 flex items-center justify-center text-text-secondary hover:border-brand hover:text-brand transition-colors"
          data-cart-dec={itemId}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
          </svg>
        </button>
        <span class="w-6 text-center text-sm font-medium" data-cart-qty={itemId}>{quantity}</span>
        <button
          class="w-7 h-7 rounded-full border border-gray-300 flex items-center justify-center text-text-secondary hover:border-brand hover:text-brand transition-colors"
          data-cart-inc={itemId}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  <button
    class="flex-shrink-0 self-start text-text-secondary hover:text-red-500 transition-colors p-1"
    data-cart-remove={itemId}
    aria-label="Hapus item"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
    </svg>
  </button>
</div>
