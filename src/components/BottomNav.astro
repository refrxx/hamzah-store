---
export interface Props {
  active?: 'home' | 'cart' | 'orders';
}

const { active = 'home' } = Astro.props;
const links = [
  { href: '/', label: 'Home', icon: 'home', key: 'home' },
  { href: '/cart', label: 'Keranjang', icon: 'cart', key: 'cart' },
  { href: '/orders', label: 'Pesanan', icon: 'orders', key: 'orders' },
];
---

<nav class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-mobile bg-white border-t border-gray-200 z-50 safe-area-bottom">
  <div class="flex items-center justify-around h-16">
    {links.map((link) => (
      <a
        href={link.href}
        class={`flex flex-col items-center justify-center w-full h-full gap-0.5 ${
          active === link.key ? 'text-brand' : 'text-text-secondary'
        }`}
      >
        {link.key === 'home' && (
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
          </svg>
        )}
        {link.key === 'cart' && (
          <div class="relative">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-1.99.9-1.99 2S15.9 22 17 22s2-.9 2-2-.9-2-2-2zM7.17 14.75l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.86-7.01L19.42 4h-.01l-1.1 2-2.76 5H8.53l-.13-.27L6.16 6l-.95-2-.94-2H1v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25z"/>
            </svg>
            <span
              data-cart-count
              class="absolute -top-2 -right-2 bg-red-500 text-white text-xs font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1 hidden"
            ></span>
          </div>
        )}
        {link.key === 'orders' && (
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
          </svg>
        )}
        <span class="text-[10px] font-medium">{link.label}</span>
      </a>
    ))}
  </div>
</nav>

<style is:global>
  .safe-area-bottom {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
</style>
