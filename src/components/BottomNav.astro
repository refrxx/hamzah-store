---
interface Props { active: 'home' | 'cart' | 'order' }
const { active } = Astro.props;
---
<nav class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-[480px] bg-white border-t z-50 flex" style="border-color:var(--border)">
  {[
    { href: '/', icon: 'home', label: 'Home', key: 'home' },
    { href: '/cart', icon: 'shopping_cart', label: 'Keranjang', key: 'cart' },
    { href: '#', icon: 'package_2', label: 'Pesanan', key: 'order' },
  ].map(nav => (
    <a href={nav.href} class={`flex-1 flex flex-col items-center py-2 gap-0.5 text-xs font-medium transition-colors ${active === nav.key ? 'text-blue-700' : ''}`} style={active === nav.key ? 'color:var(--blue)' : 'color:var(--text-secondary)'}>
      <span class="material-symbols-outlined" style="font-size:1.4rem">{nav.icon}</span>
      {nav.label}
    </a>
  ))}
</nav>
